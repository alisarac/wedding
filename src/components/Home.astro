---
import type { Lang } from "@/i18n/content";
import Base from "@/layouts/Base.astro";
import Hero from "@/components/sections/Hero.astro";
import Story from "@/components/sections/Story.astro";
import Details from "@/components/sections/Details.astro";
import Gallery from "@/components/sections/Gallery.astro";
import Rsvp from "@/components/sections/Rsvp.astro";
import Info from "@/components/sections/Info.astro";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<Base lang={lang}>
  <Hero lang={lang} />
  <Story lang={lang} />
  <Details lang={lang} />
  <Gallery lang={lang} />
  <Rsvp lang={lang} />
  <Info lang={lang} />
</Base>
