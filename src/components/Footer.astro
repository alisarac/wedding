---
import { type Lang, getDict } from "@/i18n/content";
import KilimBorder from "./motifs/KilimBorder.astro";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang);
---

<footer class="relative overflow-hidden bg-teal-deep text-cream">
  <!-- top kilim border strip -->
  <div class="border-strip w-full">
    <KilimBorder />
  </div>

  <div class="relative mx-auto max-w-3xl px-6 py-16 text-center sm:py-20">
    <p class="script text-4xl text-gold-soft sm:text-5xl">{t.footer.line}</p>
    <p class="mt-6 font-display text-sm tracking-[0.28em] uppercase text-cream/85">
      {t.footer.namesLine}
    </p>
  </div>

  <div
    class="kilim-field pointer-events-none absolute inset-0 -z-0 opacity-[0.07] mix-blend-screen"
  >
  </div>
</footer>

<style>
  .border-strip { line-height: 0; }
  .border-strip > :global(svg) { width: 100%; height: auto; display: block; }
</style>
