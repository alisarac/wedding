---
/**
 * Lush olive branch — a long curving stem arching up from the bottom
 * corner with many paired leaves and a few olive fruits, drawn as
 * filled shapes in warm sage/olive/brown. Mirrors via `flip`.
 */
interface Props {
  class?: string;
  flip?: boolean;
}
const { class: className = "", flip = false } = Astro.props;

const C = {
  stem: "#5d6240",
  leaf: "#8a9266",
  leafDeep: "#5d6240",
  leafLight: "#a8b083",
  olive: "#6e4d2a",
  oliveAlt: "#8a4d2b",
};

// Bezier stem (single C-curve) goes from bottom-left corner up to top-right.
// Sample evenly to place leaves & olives along it.
const stem = { p0: { x: 14, y: 220 }, p1: { x: 50, y: 200 }, p2: { x: 110, y: 130 }, p3: { x: 170, y: 30 } };

function pointAt(t: number) {
  const { p0, p1, p2, p3 } = stem;
  const mt = 1 - t;
  const x = mt ** 3 * p0.x + 3 * mt ** 2 * t * p1.x + 3 * mt * t ** 2 * p2.x + t ** 3 * p3.x;
  const y = mt ** 3 * p0.y + 3 * mt ** 2 * t * p1.y + 3 * mt * t ** 2 * p2.y + t ** 3 * p3.y;
  const tx = 3 * (mt ** 2 * (p1.x - p0.x) + 2 * mt * t * (p2.x - p1.x) + t ** 2 * (p3.x - p2.x));
  const ty = 3 * (mt ** 2 * (p1.y - p0.y) + 2 * mt * t * (p2.y - p1.y) + t ** 2 * (p3.y - p2.y));
  const ang = (Math.atan2(ty, tx) * 180) / Math.PI;
  return { x, y, ang };
}

// Many leaves in pairs alternating along the stem.
const leafSlots = [
  0.04, 0.1, 0.16, 0.22, 0.28, 0.34, 0.4, 0.46, 0.52, 0.58, 0.64, 0.7, 0.76, 0.82, 0.88, 0.94,
];

type Leaf = { x: number; y: number; r: number; sc: number; tone: string };
const leaves: Leaf[] = [];
leafSlots.forEach((t, i) => {
  const p = pointAt(t);
  const sc = 1 - 0.35 * t;
  const tones = [C.leaf, C.leafLight, C.leafDeep];
  // pair: one leaf out-left, one out-right (relative to stem direction)
  leaves.push({ x: p.x, y: p.y, r: p.ang + 85, sc, tone: tones[i % 3] });
  leaves.push({ x: p.x, y: p.y, r: p.ang - 85, sc: sc * 0.95, tone: tones[(i + 1) % 3] });
  // a third leaf forward for fullness
  if (i % 2 === 0) {
    leaves.push({ x: p.x, y: p.y, r: p.ang + 55, sc: sc * 0.85, tone: C.leafDeep });
  }
});

// A few olives nestled in the foliage.
const olives = [
  { t: 0.22, side: 1, c: C.olive },
  { t: 0.32, side: -1, c: C.oliveAlt },
  { t: 0.46, side: 1, c: C.olive },
  { t: 0.58, side: -1, c: C.olive },
  { t: 0.74, side: 1, c: C.oliveAlt },
].map((o) => {
  const p = pointAt(o.t);
  return { x: p.x + o.side * 5, y: p.y - 3, c: o.c };
});
---

<svg
  class={className}
  viewBox="0 0 200 240"
  fill="none"
  aria-hidden="true"
  style={flip ? "transform: scaleX(-1);" : ""}
>
  <!-- soft stem shadow -->
  <path
    d={`M${stem.p0.x} ${stem.p0.y} C ${stem.p1.x} ${stem.p1.y}, ${stem.p2.x} ${stem.p2.y}, ${stem.p3.x} ${stem.p3.y}`}
    stroke={C.stem}
    stroke-width="2.4"
    stroke-linecap="round"
    fill="none"
    opacity="0.95"
  />
  {/* small twigs branching off */}
  {[0.32, 0.55, 0.72].map((t) => {
    const p = pointAt(t);
    return (
      <g transform={`translate(${p.x} ${p.y}) rotate(${p.ang - 30})`}>
        <path d="M0 0 q -10 -8 -16 -18" stroke={C.stem} stroke-width="1.2" stroke-linecap="round" fill="none" />
      </g>
    );
  })}
  {leaves.map((l) => (
    <g transform={`translate(${l.x} ${l.y}) rotate(${l.r}) scale(${l.sc})`}>
      <path d="M0 0 C 4 -3 8 -10 10 -22 C 6 -20 2 -12 0 0 Z" fill={l.tone} />
      <path d="M1 -1 C 4 -5 7 -12 9 -20" stroke={C.leafDeep} stroke-width="0.5" stroke-opacity="0.55" fill="none" />
    </g>
  ))}
  {olives.map((o) => (
    <g>
      <ellipse cx={o.x} cy={o.y} rx="3.2" ry="4.2" fill={o.c} />
      <ellipse cx={o.x - 0.7} cy={o.y - 1.2} rx="1.1" ry="1.4" fill={C.leafLight} fill-opacity="0.55" />
    </g>
  ))}
</svg>
