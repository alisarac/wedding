---
/**
 * Olive branch — a curved stem with paired olive-shaped leaves.
 * Used in the bottom corners of the davetiye. Inherits currentColor.
 */
interface Props {
  class?: string;
  /** flip horizontally for the right corner */
  flip?: boolean;
}
const { class: className = "", flip = false } = Astro.props;

// Leaves placed along the curving stem.
const leaves = [
  { t: 0.08, side: 1, sc: 1.0 },
  { t: 0.18, side: -1, sc: 1.05 },
  { t: 0.28, side: 1, sc: 1.1 },
  { t: 0.38, side: -1, sc: 1.05 },
  { t: 0.48, side: 1, sc: 1.0 },
  { t: 0.58, side: -1, sc: 0.95 },
  { t: 0.68, side: 1, sc: 0.9 },
  { t: 0.78, side: -1, sc: 0.85 },
  { t: 0.88, side: 1, sc: 0.78 },
];

// Sample points on the stem path M10 180 C 40 140 60 80 100 20
function pointAt(t: number) {
  const x0 = 10, y0 = 180, x1 = 40, y1 = 140, x2 = 60, y2 = 80, x3 = 100, y3 = 20;
  const mt = 1 - t;
  const x = mt ** 3 * x0 + 3 * mt ** 2 * t * x1 + 3 * mt * t ** 2 * x2 + t ** 3 * x3;
  const y = mt ** 3 * y0 + 3 * mt ** 2 * t * y1 + 3 * mt * t ** 2 * y2 + t ** 3 * y3;
  // tangent direction
  const tx = 3 * (mt ** 2 * (x1 - x0) + 2 * mt * t * (x2 - x1) + t ** 2 * (x3 - x2));
  const ty = 3 * (mt ** 2 * (y1 - y0) + 2 * mt * t * (y2 - y1) + t ** 2 * (y3 - y2));
  const ang = (Math.atan2(ty, tx) * 180) / Math.PI;
  return { x, y, ang };
}

const C = { stem: "#5d6240", leaf: "#7a8254", leafDeep: "#5d6240", olive: "#8a4d2b" };
---

<svg
  class={className}
  viewBox="0 0 140 200"
  fill="none"
  aria-hidden="true"
  style={flip ? "transform: scaleX(-1);" : ""}
>
  <!-- stem -->
  <path d="M10 180 C 40 140 60 80 100 20" stroke={C.stem} stroke-width="1.4" stroke-linecap="round" fill="none" />
  {
    leaves.map((l) => {
      const p = pointAt(l.t);
      const r = p.ang + (l.side > 0 ? 70 : -70);
      return (
        <g transform={`translate(${p.x} ${p.y}) rotate(${r}) scale(${l.sc})`}>
          <path d="M0 0 C 4 -4 9 -10 12 -22 C 8 -20 3 -12 0 0 Z" fill={C.leaf} />
          <path d="M0 0 C 5 -4 9 -10 12 -22" stroke={C.leafDeep} stroke-width="0.5" stroke-opacity="0.6" fill="none" />
        </g>
      );
    })
  }
  <!-- a couple of olives -->
  <circle cx="48" cy="124" r="3.2" fill={C.olive} />
  <circle cx="56" cy="110" r="2.8" fill={C.olive} />
  <circle cx="74" cy="74" r="2.6" fill={C.olive} />
</svg>
