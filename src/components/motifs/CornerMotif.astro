---
/**
 * Corner ornament — a fine-line bracket ending in Kyrgyz "kochkor muyuz"
 * (ram's-horn) curls. Drawn for the top-left corner; rotate for others.
 * Inherits currentColor.
 */
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 50 50"
  fill="none"
  stroke="currentColor"
  stroke-width="1"
  stroke-linecap="round"
  aria-hidden="true"
>
  <!-- bracket -->
  <path d="M6 34 L6 18 C 6 11 11 6 18 6 L34 6" />
  <!-- ram's-horn curls at each end -->
  <path d="M6 18 c -3 -1 -4 -5 -1 -7 c 2 -1.4 4 0 3.6 2" />
  <path d="M18 6 c -1 -3 -5 -4 -7 -1 c -1.4 2 0 4 2 3.6" />
  <!-- inner accents -->
  <path d="M14 14 l5 5" stroke-width="0.8" />
  <circle cx="22" cy="22" r="1.1" fill="currentColor" stroke="none" />
</svg>
