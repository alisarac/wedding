---
/**
 * Ram's-horn divider — "kochkor muyuz", a core Kyrgyz/Turkic folk
 * motif. Symmetric opposed spirals flanking a kilim diamond.
 * Tints via `currentColor`.
 */
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 240 28"
  fill="none"
  stroke="currentColor"
  aria-hidden="true"
  role="presentation"
>
  <!-- left half (mirrored on the right) -->
  <g stroke-width="1.4" stroke-linecap="round">
    <line x1="6" y1="14" x2="78" y2="14" opacity="0.55" />
    <!-- ram's-horn double spiral -->
    <path d="M78 14 C 78 6, 92 6, 92 14 C 92 20, 84 20, 86 13" />
    <path d="M98 14 C 98 6, 112 6, 110 14" opacity="0.85" />
    <!-- small leaf accent -->
    <path d="M104 14 q5 -4 10 0 q-5 4 -10 0 Z" stroke-width="1.1" />
  </g>

  <g stroke-width="1.4" stroke-linecap="round" transform="translate(240,0) scale(-1,1)">
    <line x1="6" y1="14" x2="78" y2="14" opacity="0.55" />
    <path d="M78 14 C 78 6, 92 6, 92 14 C 92 20, 84 20, 86 13" />
    <path d="M98 14 C 98 6, 112 6, 110 14" opacity="0.85" />
    <path d="M104 14 q5 -4 10 0 q-5 4 -10 0 Z" stroke-width="1.1" />
  </g>

  <!-- center kilim diamond -->
  <g stroke-width="1.3">
    <path d="M120 4 L130 14 L120 24 L110 14 Z" />
    <path d="M120 9 L125 14 L120 19 L115 14 Z" fill="currentColor" fill-opacity="0.12" />
  </g>
</svg>
