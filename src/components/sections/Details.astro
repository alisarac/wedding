---
import { type Lang, getDict, site } from "@/i18n/content";
import SectionHeading from "@/components/SectionHeading.astro";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang);

const facts = [
  { label: t.details.dateLabel, value: t.details.dateValue },
  { label: t.details.timeLabel, value: t.details.timeValue },
  { label: t.details.placeLabel, value: t.details.placeValue },
  { label: t.details.dressLabel, value: t.details.dressValue },
];

const mapEmbed = `https://www.google.com/maps?q=${encodeURIComponent(
  site.mapQuery,
)}&z=16&output=embed`;
---

<section id="details" class="relative overflow-hidden bg-teal-deep px-5 py-24 text-cream sm:py-32">
  <div class="kilim-field pointer-events-none absolute inset-0 opacity-[0.06] mix-blend-screen"></div>

  <div class="relative mx-auto max-w-5xl">
    <SectionHeading eyebrow={t.details.eyebrow} title={t.details.title} tone="cream" />

    <!-- key facts -->
    <dl class="on-scroll mt-14 grid grid-cols-2 gap-px overflow-hidden rounded-sm bg-gold/20 sm:grid-cols-4">
      {
        facts.map((f) => (
          <div class="bg-teal-deep px-5 py-7 text-center">
            <dt class="eyebrow text-gold-soft">{f.label}</dt>
            <dd class="mt-3 font-display text-lg leading-snug text-cream text-balance">
              {f.value}
            </dd>
          </div>
        ))
      }
    </dl>

    <div class="mt-16 grid gap-12 md:grid-cols-2 md:gap-16">
      <!-- schedule -->
      <div class="on-scroll">
        <h3 class="font-display text-2xl text-gold-soft">{t.details.scheduleTitle}</h3>
        <ol class="mt-7 space-y-0">
          {
            t.details.schedule.map((s, i) => (
              <li class="relative flex gap-5 pb-7 last:pb-0">
                <div class="flex flex-col items-center">
                  <span class="mt-1 h-2.5 w-2.5 rotate-45 border border-gold-soft bg-teal-deep" />
                  {i < t.details.schedule.length - 1 && (
                    <span class="mt-1 w-px flex-1 bg-gold/30" />
                  )}
                </div>
                <div class="pb-1">
                  <p class="font-display text-lg text-cream">{s.time}</p>
                  <p class="text-sm tracking-wide text-cream/70">{s.label}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>

      <!-- map -->
      <div class="on-scroll" style="transition-delay:0.1s">
        <div class="overflow-hidden rounded-sm border border-gold/30 shadow-soft">
          <iframe
            src={mapEmbed}
            title={site.venueName}
            class="aspect-[4/3] w-full grayscale-[0.15]"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
        <a
          href={site.mapUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex items-center gap-2 text-sm tracking-wide text-gold-soft transition-colors hover:text-cream"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 21s7-6.3 7-11a7 7 0 10-14 0c0 4.7 7 11 7 11z" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="12" cy="10" r="2.4"/>
          </svg>
          {t.details.mapCta}
        </a>
      </div>
    </div>
  </div>
</section>
