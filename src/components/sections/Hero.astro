---
import { type Lang, getDict, site } from "@/i18n/content";
import Monogram from "@/components/motifs/Monogram.astro";
import Tunduk from "@/components/motifs/Tunduk.astro";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang);
const [first, second] = (lang === "tr" ? site.names.latin : site.names.cyrillic).split(" & ");
---

<section class="kilim-field relative flex min-h-dvh items-center justify-center overflow-hidden px-5">
  <!-- soft glow -->
  <div
    class="pointer-events-none absolute inset-0 -z-10"
    style="background: radial-gradient(60% 50% at 50% 38%, rgba(255,253,248,0.9), rgba(247,240,227,0) 70%);"
  >
  </div>
  <!-- giant tunduk watermark -->
  <Tunduk
    class="pointer-events-none absolute top-1/2 left-1/2 -z-10 h-[120vmin] w-[120vmin] -translate-x-1/2 -translate-y-1/2 text-teal/[0.045]"
  />

  <div class="flex flex-col items-center text-center">
    <Monogram class="reveal h-24 w-24 sm:h-28 sm:w-28" style="animation-delay:0.05s" />

    <p class="reveal eyebrow mt-7" style="animation-delay:0.2s">{t.hero.eyebrow}</p>

    <h1 class="reveal mt-4 leading-[0.95] text-teal-deep" style="animation-delay:0.32s">
      <span class="block text-[clamp(3rem,13vw,7.5rem)]">{first}</span>
      <span class="my-1 block font-display text-[clamp(1.4rem,4vw,2.4rem)] font-normal text-gold italic">
        &amp;
      </span>
      <span class="block text-[clamp(3rem,13vw,7.5rem)]">{second}</span>
    </h1>

    <div
      class="reveal mt-9 flex flex-col items-center gap-2 text-ink-soft"
      style="animation-delay:0.5s"
    >
      <span class="h-px w-12 bg-gold/50"></span>
      <p class="font-display text-xl tracking-wide text-teal sm:text-2xl">{t.hero.dateLine}</p>
      <p class="text-sm tracking-[0.18em] uppercase">{t.hero.venueLine}</p>
    </div>

    <a
      href="#rsvp"
      class="reveal mt-9 inline-flex items-center gap-2 rounded-full bg-teal px-7 py-3 text-sm font-medium tracking-wide text-cream shadow-soft transition-all duration-300 hover:-translate-y-0.5 hover:bg-teal-deep"
      style="animation-delay:0.68s"
    >
      {t.hero.cta}
    </a>
  </div>

  <!-- scroll cue -->
  <a
    href="#story"
    class="reveal absolute bottom-7 left-1/2 -translate-x-1/2 text-gold/70 transition-colors hover:text-gold"
    style="animation-delay:0.9s"
    aria-label="scroll"
  >
    <svg class="h-6 w-6 animate-bounce" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
      <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </a>
</section>
