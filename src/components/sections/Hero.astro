---
import { type Lang, getDict, site } from "@/i18n/content";
import KilimBand from "@/components/motifs/KilimBand.astro";
import Tulip from "@/components/motifs/Tulip.astro";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang);
const [first, second] = (lang === "tr" ? site.names.latin : site.names.cyrillic).split(" & ");
const conj = lang === "tr" ? "ve" : "и";
---

<section class="relative flex min-h-dvh items-center justify-center overflow-hidden bg-cream px-[20%] sm:px-[21%] lg:px-[22%]">
  <!-- vertical kilim bands flanking the hero -->
  <div class="band band--left pointer-events-none absolute inset-y-0 left-0 z-0">
    <KilimBand />
  </div>
  <div class="band band--right pointer-events-none absolute inset-y-0 right-0 z-0">
    <KilimBand />
  </div>

  <!-- soft glow -->
  <div
    class="pointer-events-none absolute inset-0 z-0"
    style="background: radial-gradient(60% 50% at 50% 38%, rgba(255,248,228,0.85), rgba(247,236,204,0) 70%);"
  >
  </div>

  <div class="relative z-10 flex w-full max-w-2xl flex-col items-center text-center">
    <p class="reveal eyebrow mt-2" style="animation-delay:0.1s">{t.hero.eyebrow}</p>

    <h1
      class="reveal mt-6 leading-[0.92] text-ink"
      style="animation-delay:0.28s"
    >
      <span class="block text-[clamp(2.6rem,11vw,6rem)] tracking-[0.18em] pl-[0.18em]">{first}</span>
      <span class="my-1 block script text-[clamp(2rem,6vw,3.4rem)] font-normal text-teal">
        {conj}
      </span>
      <span class="block text-[clamp(2.6rem,11vw,6rem)] tracking-[0.18em] pl-[0.18em]">{second}</span>
    </h1>

    <!-- tulip ornament -->
    <div class="reveal mt-6 flex items-center gap-3 text-teal-deep" style="animation-delay:0.42s">
      <span class="h-px w-12 sm:w-20 bg-teal-deep/50"></span>
      <Tulip class="h-8 w-8" />
      <span class="h-px w-12 sm:w-20 bg-teal-deep/50"></span>
    </div>

    <div
      class="reveal mt-6 flex flex-col items-center gap-2 text-ink-soft"
      style="animation-delay:0.55s"
    >
      <p class="font-display text-xl tracking-wide text-ink sm:text-2xl">{t.hero.dateLine}</p>
      <p class="text-sm tracking-[0.22em] uppercase">{t.hero.venueLine}</p>
    </div>

    <a
      href="#rsvp"
      class="reveal mt-8 inline-flex items-center gap-2 bg-teal px-7 py-3 text-sm font-medium tracking-[0.18em] uppercase text-cream shadow-soft transition-all duration-300 hover:-translate-y-0.5 hover:bg-teal-deep"
      style="animation-delay:0.68s"
    >
      {t.hero.cta}
    </a>
  </div>

  <!-- scroll cue -->
  <a
    href="#story"
    class="reveal absolute bottom-6 left-1/2 z-10 -translate-x-1/2 text-teal/70 transition-colors hover:text-teal-deep"
    style="animation-delay:0.9s"
    aria-label="scroll"
  >
    <svg class="h-6 w-6 animate-bounce" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
      <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </a>
</section>

<style>
  .band { width: 14%; line-height: 0; }
  .band > :global(svg) { width: 100%; height: 100%; display: block; }
  @media (min-width: 640px) { .band { width: 15%; } }
  @media (min-width: 1024px) { .band { width: 17%; } }
</style>
