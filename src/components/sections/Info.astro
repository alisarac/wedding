---
import { type Lang, getDict } from "@/i18n/content";
import SectionHeading from "@/components/SectionHeading.astro";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang);
---

<section id="info" class="bg-cream-deep px-5 py-24 sm:py-32">
  <div class="mx-auto max-w-5xl">
    <SectionHeading eyebrow={t.info.eyebrow} title={t.info.title} />

    <div class="mt-14 grid gap-6 sm:grid-cols-3">
      {
        t.info.items.map((item, i) => (
          <article
            class="on-scroll relative rounded-sm border border-teal/10 bg-paper p-7 shadow-soft"
            style={`transition-delay:${i * 0.1}s`}
          >
            <span
              class="absolute top-4 right-5 font-display text-3xl text-gold/30"
              aria-hidden="true"
            >
              0{i + 1}
            </span>
            <h3 class="font-display text-xl text-teal-deep">{item.title}</h3>
            <span class="mt-3 block h-px w-10 bg-gold/50"></span>
            <p class="mt-4 leading-relaxed text-ink-soft">{item.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
