---
import "@/styles/global.css";
import { type Lang, getDict, site } from "@/i18n/content";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getDict(lang);
const base = import.meta.env.BASE_URL;
const canonical = new URL(`${base}${lang}/`, Astro.site ?? "https://ulya.alisrc.com");
const trUrl = new URL(`${base}tr/`, Astro.site ?? "https://ulya.alisrc.com").href;
const ruUrl = new URL(`${base}ru/`, Astro.site ?? "https://ulya.alisrc.com").href;
---

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t.meta.title}</title>
    <meta name="description" content={t.meta.description} />
    <link rel="canonical" href={canonical.href} />
    <link rel="alternate" hreflang="tr" href={trUrl} />
    <link rel="alternate" hreflang="ru" href={ruUrl} />
    <link rel="alternate" hreflang="x-default" href={trUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={t.meta.title} />
    <meta property="og:description" content={t.meta.description} />
    <meta property="og:locale" content={lang === "tr" ? "tr_TR" : "ru_RU"} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Lora:ital,wght@0,400;0,500;1,400&display=swap"
      rel="stylesheet"
    />

    <meta name="theme-color" content="#1c4a4f" />
  </head>
  <body class="min-h-dvh antialiased">
    <Header lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />

    <script>
      // Scroll-triggered reveals.
      const els = document.querySelectorAll<HTMLElement>(".on-scroll");
      if ("IntersectionObserver" in window && els.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" },
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add("is-visible"));
      }
    </script>
  </body>
</html>
