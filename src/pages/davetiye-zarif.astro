---
import { site } from "@/i18n/content";

const title = "Ulya & Ali · Düğün Davetiyesi";
const description =
  "25 Temmuz 2026 · Güzelcehisar Garden, İstanbul. Düğünümüze davetlisiniz.";
---

<!doctype html>
<html lang="tr">
  <head>
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap"
      rel="stylesheet"
    />
    <meta name="theme-color" content="#f5f1e8" />
  </head>

  <body class="stage">
    <main class="wrap">
      <article class="card">
        <span class="frame" aria-hidden="true"></span>

        <div class="inner">
          <!-- top group -->
          <div class="top">
            <p class="eyebrow reveal" style="animation-delay:0.14s">Evleniyoruz</p>
          </div>

          <!-- names: the commanding moment -->
          <h1 class="names reveal" style="animation-delay:0.26s">
            <span class="names__row">Ulya</span>
            <span class="names__amp">&amp;</span>
            <span class="names__row">Ali</span>
          </h1>

          <div class="rule reveal" style="animation-delay:0.4s">
            <span></span><i></i><span></span>
          </div>

          <p class="invite reveal" style="animation-delay:0.5s">
            En özel günümüz olan düğün törenimizde, sizi de aramızda görmekten
            mutluluk duyarız.
          </p>

          <!-- children note, above the date -->
          <p class="note reveal" style="animation-delay:0.6s">
            Minik misafirlerimiz, sizleri çok sevsek de bu akşam tatlı
            rüyalarda olmanızı diliyoruz. İyi geceler.
          </p>

          <!-- details -->
          <div class="meta reveal" style="animation-delay:0.68s">
            <p class="meta__date">25 Temmuz 2026</p>
            <p class="meta__sub">Cumartesi &nbsp;·&nbsp; 19.00</p>
            <p class="meta__venue">{site.venueName}</p>
            <p class="meta__addr">Otağtepe, Kavacık &nbsp;·&nbsp; Beykoz / İstanbul</p>
          </div>
        </div>
      </article>

      <p class="hint">Yazdırmak veya PDF için Ctrl/Cmd + P</p>
    </main>
  </body>

  <style>
    :root {
      --paper: #f6f2e9;
      --ink: #2a2722;
      --ink-soft: #837a6d;
      --gold: #a8854c;
      --gold-soft: #c3a574;
      --display: "Playfair Display", Georgia, serif;
      --serif: "Cormorant Garamond", "Times New Roman", serif;
    }

    .stage {
      margin: 0;
      min-height: 100dvh;
      background: #e7e1d4;
      display: grid;
      place-items: center;
      padding: clamp(1rem, 4vw, 3rem) 1rem;
    }
    .wrap { display: flex; flex-direction: column; align-items: center; gap: 1.1rem; }

    .card {
      position: relative;
      width: min(94vw, 520px);
      min-height: min(150vh, 748px);
      display: flex;
      background:
        radial-gradient(120% 80% at 50% 0%, #faf7ef, var(--paper) 60%);
      box-shadow: 0 34px 80px -34px rgba(60, 52, 38, 0.5);
    }

    .frame {
      position: absolute;
      inset: clamp(0.85rem, 2.6vw, 1.25rem);
      border: 1px solid color-mix(in srgb, var(--gold) 45%, transparent);
      pointer-events: none;
    }

    .inner {
      flex: 1;
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: clamp(1rem, 3vh, 1.9rem);
      text-align: center;
      padding: clamp(3rem, 11%, 4.6rem) clamp(2rem, 9%, 3.4rem);
    }

    .top { display: flex; flex-direction: column; align-items: center; }

    .eyebrow {
      font-family: var(--serif);
      font-style: italic;
      font-weight: 400;
      letter-spacing: 0.46em;
      text-transform: uppercase;
      font-size: 0.74rem;
      color: var(--gold);
      margin: 0;
      padding-left: 0.46em;
    }

    .names {
      font-family: var(--display);
      font-weight: 400;
      color: var(--ink);
      line-height: 0.96;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.04em;
      margin: 0;
    }
    .names__row { font-size: clamp(3.4rem, 13vh, 5.6rem); letter-spacing: 0.005em; }
    .names__amp {
      font-family: var(--serif);
      font-style: italic;
      font-weight: 400;
      color: var(--gold);
      font-size: clamp(1.4rem, 4vh, 2.1rem);
      line-height: 1;
      margin: 0.04em 0;
    }

    .rule { display: flex; align-items: center; justify-content: center; gap: 0.6rem; }
    .rule span { width: clamp(34px, 9vw, 54px); height: 1px; background: color-mix(in srgb, var(--gold) 60%, transparent); }
    .rule i { width: 4px; height: 4px; transform: rotate(45deg); background: var(--gold); display: block; }

    .invite {
      font-family: var(--serif);
      font-weight: 400;
      color: var(--ink-soft);
      max-width: 26ch;
      font-size: clamp(1.02rem, 2.3vh, 1.22rem);
      line-height: 1.55;
      margin: 0;
      text-wrap: balance;
    }

    .meta { display: flex; flex-direction: column; align-items: center; gap: 0.18rem; }
    .meta__date {
      font-family: var(--display);
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-size: clamp(1.05rem, 2.5vh, 1.3rem);
      color: var(--ink);
      margin: 0;
    }
    .meta__sub {
      font-family: var(--serif);
      letter-spacing: 0.34em;
      text-transform: uppercase;
      font-size: 0.74rem;
      color: var(--gold);
      margin: 0.1rem 0 0.7rem;
      padding-left: 0.34em;
    }
    .meta__venue {
      font-family: var(--serif);
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      font-size: 0.92rem;
      color: var(--ink);
      margin: 0;
      padding-left: 0.2em;
    }
    .meta__addr {
      font-family: var(--serif);
      letter-spacing: 0.06em;
      font-size: 0.86rem;
      color: var(--ink-soft);
      margin: 0.22rem 0 0;
    }

    .note {
      font-family: var(--serif);
      font-style: italic;
      font-size: 0.84rem;
      line-height: 1.5;
      max-width: 32ch;
      color: var(--ink-soft);
      margin: 0;
    }

    .hint { font-family: var(--serif); font-size: 0.88rem; letter-spacing: 0.04em; color: #9b9384; }

    .reveal { opacity: 0; transform: translateY(12px); animation: rise 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
    @keyframes rise { to { opacity: 1; transform: translateY(0); } }

    @page { size: A4 portrait; margin: 0; }
    @media print {
      .stage { background: #fff; padding: 0; display: block; }
      .hint { display: none; }
      .card { width: 100%; min-height: 0; height: 100vh; box-shadow: none; }
      :global(html), :global(body) { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    }
    @media (prefers-reduced-motion: reduce) { .reveal { animation: none; opacity: 1; transform: none; } }
  </style>
</html>
