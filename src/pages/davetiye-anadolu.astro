---
const base = import.meta.env.BASE_URL;
const img = `${base}davetiye-original.jpeg`;
const title = "Ulya & Ali · Düğün Davetiyesi";
const description =
  "25 Temmuz 2026 · Güzelcehisar Garden, Otağtepe / Kavacık, Beykoz / İstanbul.";
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={img} />
    <meta name="theme-color" content="#f0dac8" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <main>
      <figure>
        <img src={img} alt={title} fetchpriority="high" />
      </figure>
      <p class="hint">
        Yazdırmak veya PDF olarak kaydetmek için Ctrl/Cmd + P · İndirmek için
        <a href={img} download="ulya-ali-davetiye.jpeg">tıklayın</a>.
      </p>
    </main>

    <style>
      body {
        margin: 0;
        min-height: 100dvh;
        background: #d9c79b;
        display: grid;
        place-items: center;
        padding: clamp(1rem, 4vw, 2.5rem) 1rem;
        font-family: "Cormorant Garamond", Georgia, serif;
      }
      main {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        width: 100%;
      }
      figure {
        margin: 0;
        width: min(94vw, 560px);
        aspect-ratio: 1064 / 1479;
        box-shadow: 0 32px 70px -32px rgba(60, 40, 22, 0.55);
        background: #f0dac8;
      }
      figure img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .hint {
        font-size: 0.92rem;
        color: #4a3a26;
        font-style: italic;
        margin: 0;
        text-align: center;
      }
      .hint a {
        color: #8a3f25;
        text-decoration: none;
        border-bottom: 1px solid currentColor;
      }

      @page { size: A4 portrait; margin: 0; }
      @media print {
        body { background: #fff; padding: 0; display: block; }
        .hint { display: none; }
        figure {
          width: 100%;
          height: 100vh;
          aspect-ratio: auto;
          box-shadow: none;
        }
        figure img { object-fit: contain; }
        :global(html), :global(body) {
          -webkit-print-color-adjust: exact;
          print-color-adjust: exact;
        }
      }
    </style>
  </body>
</html>
