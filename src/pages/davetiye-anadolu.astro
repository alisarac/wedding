---
import { site } from "@/i18n/content";
import KilimBand from "@/components/motifs/KilimBand.astro";
import KilimBorder from "@/components/motifs/KilimBorder.astro";
import Tulip from "@/components/motifs/Tulip.astro";
import OliveBranch from "@/components/motifs/OliveBranch.astro";
import Landscape from "@/components/motifs/Landscape.astro";

const title = "Ulya & Ali · Düğün Davetiyesi";
const description =
  "25 Temmuz 2026 · Güzelcehisar Garden, İstanbul. Düğünümüze davetlisiniz.";
---

<!doctype html>
<html lang="tr">
  <head>
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Italianno&display=swap"
      rel="stylesheet"
    />
    <meta name="theme-color" content="#f6e8c5" />
  </head>

  <body class="stage">
    <main class="wrap">
      <article class="card">
        <!-- kilim side bands -->
        <span class="band band--left" aria-hidden="true"><KilimBand /></span>
        <span class="band band--right" aria-hidden="true"><KilimBand /></span>

        <!-- center column -->
        <div class="inner">
          <p class="intro reveal" style="animation-delay:0.05s">
            BİRBİRİMİZİ BULDUK,<br />
            AİLELERİMİZLE BÜTÜNLENDİK.
          </p>
          <p class="subintro reveal" style="animation-delay:0.15s">
            Bu özel günümüzde<br />sizleri de aramızda görmekten mutluluk duyarız.
          </p>

          <span class="orn reveal" aria-hidden="true" style="animation-delay:0.22s">
            <svg viewBox="0 0 80 12" fill="none">
              <path d="M10 6 L40 6 M40 6 L70 6" stroke="#8a4d2b" stroke-width="0.9" />
              <path d="M40 1 L46 6 L40 11 L34 6 Z" fill="#b5613b" />
            </svg>
          </span>

          <h1 class="names reveal" style="animation-delay:0.32s">
            <span class="names__row">ULYA</span>
            <span class="names__amp">ve</span>
            <span class="names__row">ALİ</span>
          </h1>

          <span class="orn orn--tulip reveal" aria-hidden="true" style="animation-delay:0.42s">
            <svg viewBox="0 0 200 24" fill="none">
              <line x1="10" y1="12" x2="80" y2="12" stroke="#8a4d2b" stroke-width="0.9" />
              <line x1="120" y1="12" x2="190" y2="12" stroke="#8a4d2b" stroke-width="0.9" />
            </svg>
            <Tulip class="orn__tulip" />
          </span>

          <!-- info row -->
          <div class="info reveal" style="animation-delay:0.5s">
            <div class="info__col">
              <svg class="info__icon" viewBox="0 0 24 24" fill="none" stroke="#5d6240" stroke-width="1.4" stroke-linecap="round">
                <rect x="3" y="5" width="18" height="16" rx="1.5" />
                <path d="M3 9 H21" />
                <path d="M8 3 V7 M16 3 V7" />
                <circle cx="8" cy="14" r="0.9" fill="#5d6240" />
                <circle cx="12" cy="14" r="0.9" fill="#5d6240" />
                <circle cx="16" cy="14" r="0.9" fill="#5d6240" />
              </svg>
              <p class="info__big">25</p>
              <p class="info__small">TEMMUZ<br />2026<br />CUMARTESİ</p>
            </div>
            <div class="info__sep"></div>
            <div class="info__col">
              <svg class="info__icon" viewBox="0 0 24 24" fill="none" stroke="#5d6240" stroke-width="1.4" stroke-linecap="round">
                <circle cx="12" cy="12" r="9" />
                <path d="M12 7 V12 L15 14" />
              </svg>
              <p class="info__big">19.00</p>
              <p class="info__small">NİKAH &amp; DAVET</p>
            </div>
            <div class="info__sep"></div>
            <div class="info__col info__col--addr">
              <svg class="info__icon" viewBox="0 0 24 24" fill="none" stroke="#5d6240" stroke-width="1.4" stroke-linecap="round">
                <path d="M12 21 C 17 16 19 13 19 9 A 7 7 0 0 0 5 9 C 5 13 7 16 12 21 Z" />
                <circle cx="12" cy="9" r="2.4" />
              </svg>
              <p class="info__venue">{site.venueName}</p>
              <p class="info__addr">Otağtepe, Kavacık,<br />Muhteşem Çk. No:25,<br />İstanbul</p>
            </div>
          </div>

          <span class="orn orn--mini reveal" aria-hidden="true" style="animation-delay:0.6s">
            <svg viewBox="0 0 120 14" fill="none">
              <line x1="0" y1="7" x2="40" y2="7" stroke="#8a4d2b" stroke-width="0.9" />
              <path d="M50 1 L58 7 L50 13 L42 7 Z" fill="#b5613b" />
              <path d="M60 1 L68 7 L60 13 L52 7 Z" fill="#7a8254" />
              <path d="M70 1 L78 7 L70 13 L62 7 Z" fill="#b5613b" />
              <line x1="80" y1="7" x2="120" y2="7" stroke="#8a4d2b" stroke-width="0.9" />
            </svg>
          </span>

          <p class="note reveal" style="animation-delay:0.68s">
            Değerli misafirlerimizin konforunu düşünerek,<br />
            bu özel günümüzde çocuklarımıza
          </p>
          <p class="note__emph reveal" style="animation-delay:0.74s">İYİ GECELER DİLERİZ.</p>

          <p class="seats reveal" style="animation-delay:0.82s">
            Davetiyemiz iki kişiliktir.
          </p>
        </div>

        <!-- coastal landscape silhouette between branches -->
        <span class="landscape" aria-hidden="true"><Landscape /></span>

        <!-- bottom corner branches -->
        <span class="branch branch--left" aria-hidden="true"><OliveBranch /></span>
        <span class="branch branch--right" aria-hidden="true"><OliveBranch flip /></span>

        <!-- bottom kilim border -->
        <span class="border" aria-hidden="true"><KilimBorder /></span>

        <p class="closing reveal" style="animation-delay:0.92s">Sevgilerle bekliyoruz.</p>
      </article>

      <p class="hint">Yazdırmak veya PDF için Ctrl/Cmd + P</p>
    </main>
  </body>

  <style>
    :root {
      --paper: #f7eccc;
      --paper-2: #f1dfaf;
      --ink: #3a2c20;
      --ink-soft: #6e5a3f;
      --terra: #b5613b;
      --terra-deep: #8a4d2b;
      --olive: #7a8254;
      --olive-deep: #5d6240;
      --brown: #5a3a25;
      --rust: #a04525;
      --gold: #b89163;
      --serif: "Cormorant Garamond", "Times New Roman", serif;
      --script: "Italianno", "Brush Script MT", cursive;
    }

    .stage {
      margin: 0;
      min-height: 100dvh;
      background: #d9c79b;
      display: grid;
      place-items: center;
      padding: clamp(1rem, 4vw, 3rem) 1rem;
    }
    .wrap { display: flex; flex-direction: column; align-items: center; gap: 1rem; }

    .card {
      position: relative;
      width: min(94vw, 560px);
      min-height: min(160vh, 820px);
      background:
        radial-gradient(120% 80% at 50% 10%, #fbf4d9, var(--paper) 65%);
      box-shadow: 0 32px 70px -30px rgba(60, 40, 22, 0.55);
      overflow: hidden;
      display: flex;
    }

    /* kilim side bands */
    .band {
      position: absolute;
      top: 0;
      bottom: 0;
      width: 13%;
      pointer-events: none;
      line-height: 0;
    }
    .band--left { left: 0; }
    .band--right { right: 0; }
    .band :global(svg) { width: 100%; height: 100%; display: block; }

    /* center column */
    .inner {
      position: relative;
      z-index: 2;
      flex: 1;
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      text-align: center;
      padding: 2.4rem 18% 5rem;
      gap: 0.8rem;
    }

    .intro {
      font-family: var(--serif);
      font-weight: 600;
      letter-spacing: 0.14em;
      font-size: 0.95rem;
      color: var(--ink);
      line-height: 1.55;
      margin: 0;
    }

    .subintro {
      font-family: var(--serif);
      font-style: italic;
      font-weight: 500;
      font-size: 1.05rem;
      color: var(--terra-deep);
      line-height: 1.5;
      margin: 0.5rem 0 0.7rem;
    }

    .orn { display: block; line-height: 0; }
    .orn svg { width: 110px; height: auto; display: block; margin: 0 auto; }
    .orn--tulip { position: relative; display: flex; align-items: center; justify-content: center; }
    .orn--tulip svg:first-child { width: 280px; }
    .orn--tulip :global(.orn__tulip) { position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); width: 52px; height: auto; }

    .names {
      font-family: var(--serif);
      font-weight: 400;
      color: var(--ink);
      line-height: 0.95;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.05em;
      margin: 0.3rem 0 0.4rem;
    }
    .names__row {
      font-size: 3.1rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      padding-left: 0.28em;
    }
    .names__amp {
      font-family: var(--script);
      font-size: 3rem;
      color: var(--terra);
      line-height: 1;
      margin: -0.1em 0;
      letter-spacing: 0;
      padding-left: 0;
    }

    .info {
      display: grid;
      grid-template-columns: 1fr auto 1fr auto 1fr;
      align-items: start;
      gap: 0.6rem;
      width: 100%;
      max-width: 100%;
      margin: 0.4rem 0 0.4rem;
    }
    .info__col { display: flex; flex-direction: column; align-items: center; gap: 0.3rem; }
    .info__sep { width: 1px; align-self: stretch; background: color-mix(in srgb, var(--terra-deep) 25%, transparent); margin: 0.4rem 0; }
    .info__icon { width: 24px; height: 24px; color: var(--olive-deep); }
    .info__big {
      font-family: var(--serif);
      font-weight: 600;
      font-size: 1.6rem;
      color: var(--ink);
      margin: 0.1rem 0 0;
      line-height: 1;
    }
    .info__small {
      font-family: var(--serif);
      font-weight: 500;
      font-size: 0.78rem;
      letter-spacing: 0.12em;
      color: var(--ink);
      margin: 0;
      line-height: 1.45;
    }
    .info__venue {
      font-family: var(--serif);
      font-weight: 700;
      font-size: 0.92rem;
      letter-spacing: 0.08em;
      color: var(--ink);
      margin: 0.1rem 0 0;
      line-height: 1.2;
    }
    .info__addr {
      font-family: var(--serif);
      font-weight: 500;
      font-size: 0.82rem;
      color: var(--ink);
      line-height: 1.45;
      margin: 0.25rem 0 0;
    }

    .note {
      font-family: var(--serif);
      font-style: italic;
      font-weight: 500;
      font-size: 1.02rem;
      color: var(--ink);
      line-height: 1.5;
      margin: 0.3rem 0 0;
    }
    .note__emph {
      font-family: var(--serif);
      font-weight: 700;
      letter-spacing: 0.14em;
      font-size: 0.98rem;
      color: var(--terra-deep);
      margin: 0.25rem 0 0;
    }
    .seats {
      font-family: var(--serif);
      font-style: italic;
      font-weight: 500;
      font-size: 0.95rem;
      color: var(--brown);
      margin: 0.55rem 0 0;
      line-height: 1;
    }

    /* bottom corner branches */
    .branch {
      position: absolute;
      bottom: 3.4rem;
      width: 32%;
      pointer-events: none;
      z-index: 2;
      line-height: 0;
    }
    .branch--left { left: 11%; }
    .branch--right { right: 11%; }
    .branch :global(svg) { width: 100%; height: auto; display: block; }

    /* coastal landscape (chapel + waves + palms + pergola) */
    .landscape {
      position: absolute;
      left: 13%;
      right: 13%;
      bottom: 3.8rem;
      line-height: 0;
      z-index: 1;
      pointer-events: none;
      opacity: 0.92;
    }
    .landscape :global(svg) { width: 100%; height: auto; display: block; }

    /* bottom kilim border */
    .border {
      position: absolute;
      left: 13%;
      right: 13%;
      bottom: 1.6rem;
      line-height: 0;
      z-index: 3;
    }
    .border :global(svg) { width: 100%; height: auto; display: block; }

    .closing {
      position: absolute;
      left: 50%;
      bottom: 0.5rem;
      transform: translateX(-50%);
      font-family: var(--serif);
      font-style: italic;
      font-weight: 600;
      font-size: 0.9rem;
      letter-spacing: 0.04em;
      color: var(--terra-deep);
      margin: 0;
      line-height: 1;
      z-index: 4;
      white-space: nowrap;
    }

    .hint { font-family: var(--serif); font-size: 0.88rem; letter-spacing: 0.04em; color: #6e5a3f; }

    .reveal { opacity: 0; transform: translateY(10px); animation: rise 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
    @keyframes rise { to { opacity: 1; transform: translateY(0); } }

    @page { size: A4 portrait; margin: 0; }
    @media print {
      .stage { background: #fff; padding: 0; display: block; }
      .hint { display: none; }
      .card { width: 100%; min-height: 0; height: 100vh; box-shadow: none; }
      :global(html), :global(body) { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    }
    @media (prefers-reduced-motion: reduce) { .reveal { animation: none; opacity: 1; transform: none; } }
  </style>
</html>
